# ─── Supabase ────────────────────────────────────────────────
# Get these from your Supabase project settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...           # server-only, never expose

# ─── Database ────────────────────────────────────────────────
# Direct Postgres connection (use the pooled connection string for runtime,
# the direct one for migrations). Both come from Supabase → Database settings.
DATABASE_URL=postgresql://postgres:PASS@db.PROJECT.supabase.co:5432/postgres
DATABASE_POOLER_URL=postgresql://postgres:PASS@aws-0-region.pooler.supabase.com:6543/postgres

# ─── Email (Brevo) ───────────────────────────────────────────
BREVO_API_KEY=xkeysib-...
BREVO_FROM_EMAIL=concierge@saanguine.com
BREVO_FROM_NAME=Maison Saanguine

# ─── SMS (SSL Wireless — BD) ─────────────────────────────────
SSLWIRELESS_API_TOKEN=
SSLWIRELESS_SID=

# ─── Shipping (Pathao + Steadfast) ───────────────────────────
PATHAO_BASE_URL=https://api-hermes.pathao.com
PATHAO_CLIENT_ID=
PATHAO_CLIENT_SECRET=
PATHAO_USERNAME=
PATHAO_PASSWORD=
PATHAO_STORE_ID=

STEADFAST_BASE_URL=https://portal.packzy.com/api/v1
STEADFAST_API_KEY=
STEADFAST_SECRET_KEY=

# ─── Sanity (CMS) ────────────────────────────────────────────
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_API_READ_TOKEN=
SANITY_API_WRITE_TOKEN=

# ─── Cloudinary (images) ─────────────────────────────────────
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── Observability ───────────────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ─── Site ────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000
